# ---------- Server ----------
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# ---------- JWT ----------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_hex_string
JWT_EXPIRES_IN=7d            # user tokens
ADMIN_JWT_EXPIRES_IN=24h     # admin tokens
JWT_COOKIE_NAME=nova_token
ADMIN_JWT_COOKIE_NAME=nova_admin_token

# ---------- Supabase ----------
# Get these from: https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---------- Nodemailer (SMTP) ----------
# For Gmail, generate an "App Password" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Nova Capital <no-reply@nova.capital>"

# ---------- App ----------
APP_NAME=Nova Capital
APP_URL=http://localhost:3000
